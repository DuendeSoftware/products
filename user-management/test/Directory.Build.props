<Project>
  <Import Project="$([MSBuild]::GetPathOfFileAbove('Directory.Build.props', '$(MSBuildThisFileDirectory)..\'))" />
  <Import Project="../../test.props" />
  <PropertyGroup>
    <!-- TODO: Fix these in platform test code and remove suppressions -->
