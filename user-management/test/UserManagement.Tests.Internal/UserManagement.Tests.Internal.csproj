<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <AssemblyName>Duende.UserManagement.Tests.Internal</AssemblyName>
    <RootNamespace>Duende.Platform.UserManagement</RootNamespace>
  </PropertyGroup>

  <PropertyGroup>
    <!-- Namespace does not match folder structure --> <!--todo: remove-->
    <NoWarn>$(NoWarn);IDE0130</NoWarn>

    <!-- async suffix for test methods -->
    <NoWarn>$(NoWarn);IDE0106</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\src\UserManagement\UserManagement.csproj" />
    <ProjectReference Include="..\..\testing\UserManagement.TestInfrastructure\UserManagement.TestInfrastructure.csproj" />
  </ItemGroup>
  <ItemGroup>
    <!-- MimeKit is a direct dependency to override netDumbster's transitive MimeKit 3.1.1,
         which has known vulnerabilities (GHSA-g7hc-96xr-gvvx, GHSA-gmc6-fwg3-75m5). -->
    <PackageReference Include="MimeKit" />
    <PackageReference Include="netDumbster" />
    <PackageReference Include="System.Drawing.Common" />
    <PackageReference Include="Verify.XunitV3" />
  </ItemGroup>
  <ItemGroup>
    <Using Include="Microsoft.Extensions.Time.Testing" />
    <Using Include="Shouldly" />
  </ItemGroup>
</Project>