<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <AssemblyName>Duende.UserManagement</AssemblyName>
    <RootNamespace>Duende.UserManagement</RootNamespace>
    <NoWarn>$(NoWarn);ca1812</NoWarn> <!-- never instantiated internal class-->

  </PropertyGroup>

  <ItemGroup>
    <None Remove="Authentication\Passkeys\passkeys.js"/>
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Authentication\Passkeys\passkeys.js"/>
  </ItemGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App"/>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Duende.IdentityModel"/>
    <PackageReference Include="Duende.Private.Licensing"/>
    <PackageReference Include="Duende.Storage"/>
  </ItemGroup>

</Project>
