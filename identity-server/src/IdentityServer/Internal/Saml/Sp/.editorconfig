[*.cs]
# Suppress all analyzer diagnostics for imported Sustainsys SP code.
# This code was imported as-is from Sustainsys.Saml2 and is not subject to
# the same coding standards as the rest of IdentityServer.

# IDE style rules
dotnet_diagnostic.IDE0007.severity = none
dotnet_diagnostic.IDE0011.severity = none
dotnet_diagnostic.IDE0021.severity = none
dotnet_diagnostic.IDE0022.severity = none
dotnet_diagnostic.IDE0025.severity = none
dotnet_diagnostic.IDE0027.severity = none
dotnet_diagnostic.IDE0066.severity = none
dotnet_diagnostic.IDE0161.severity = none

# CA correctness / design rules
