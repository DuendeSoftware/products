<?xml version="1.0" encoding="utf-8"?>
<Project>
  <Import Project="$([MSBuild]::GetPathOfFileAbove('Directory.Build.props', '$(MSBuildThisFileDirectory)..\'))" />
  <PropertyGroup>
    <IsPackable>false</IsPackable>
    <IsIdSrvProject>true</IsIdSrvProject>
    <ManagePackageVersionsCentrally>false</ManagePackageVersionsCentrally>
    <AnalysisMode>None</AnalysisMode>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>

  <!-- Pin vulnerable transitive dependency (templates opt out of CPM so GlobalPackageReference doesn't apply) -->
  <ItemGroup>
    <PackageReference Include="SQLitePCLRaw.bundle_e_sqlite3" Version="3.0.3" PrivateAssets="all" />
  </ItemGroup>
</Project>
