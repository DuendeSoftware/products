@page
@model IdentityServerTemplate.Pages.Admin.Federation.IndexModel

<div class="container-fluid mb-4 px-0">

    <header class="pb-3 mb-4 border-bottom">
        <h1 class=" fw-bold">
            <i class="bi bi-unlock2 text-brand"></i>
            Federation
        </h1>
        <span class="text-muted">
            Manage social and enterprise external authentication providers.
        </span>
    </header>

    @if (Model.ProviderConfigurationInfo.Count() > 0 && !Model.IsLicensed)
    {
        <div class="alert alert-info mt-4" role="alert">
            Dynamic providers are a <a href="https://duendesoftware.com/products/identityserver" class="alert-link">Duende IdentityServer Enterprise feature</a>,
            which is not included in your current license.<br/>
            <a href="https://duendesoftware.com/contact/sales" class="alert-link">Contact us</a> for more information.
        </div>
    }

    <div class="d-flex justify-content-end align-items-end bg-body-tertiary p-2 flex-nowrap">

        <!-- Actions: keep dropdown + form together, no wrap -->
        <div class="d-flex align-items-center flex-nowrap gap-2">

            <!-- Create dropdown -->
            <div class="dropdown">
                <button class="btn btn-outline-primary dropdown-toggle text-decoration-none"
                        type="button"
                        data-bs-toggle="dropdown"
                        aria-expanded="false">
                    Create External Provider
                </button>
                <ul class="dropdown-menu">
                    @foreach (var providerConfigurationInfo in Model.ProviderConfigurationInfo)
                    {
                        <li><a class="dropdown-item" asp-page="/Admin/Federation/New" asp-route-type="@providerConfigurationInfo.Type">@providerConfigurationInfo.Name</a></li>
                    }
                </ul>
            </div>

            <!-- Filter/Search form -->
            <form role="search" class="row g-2 flex-grow-1 align-items-end">

                <div class="col-auto">
                    <input class="form-control me-2"
                           type="text"
                           id="filter"
                           name="filter"
                           placeholder="Filter"
                           value="@Model.Filter" />
                </div>

                <div class="col-auto">
                    <button class="btn btn-brand" type="submit">
                        <i class="bi bi-filter"></i>
                        Filter
                    </button>
                </div>
            </form>

        </div>
    </div>
</div>


<table class="table table-hover">
    <thead>
        <tr>
            <th></th>
            <th>Name</th>
            <th>Type</th>
            <th>Enabled</th>
            <th><span class="d-none">Actions</span></th>
        </tr>
    </thead>
    <tbody class="table-group-divider">
        @foreach (var provider in Model.Providers)
        {
          <tr>
            <td>
              @if (!string.IsNullOrEmpty(provider.Configuration.IconUrl))
              {
                <img src="@provider.Configuration.IconUrl" alt="@provider.Name" width="32" height="32" class="me-2">
              }
            </td>
            <td class="align-middle fw-bold">
              @if (string.IsNullOrWhiteSpace(provider.Name))
              {
                <i class='text-muted fst-italic'>(No name)</i>
              }
              else
              {
                @provider.Name
              }
              <br />
              <small class="text-muted">Scheme: @provider.Scheme</small>
            </td>
            <td class="align-middle">@provider.Configuration.ToFriendlyType()</td>
            <td class="align-middle">
              @(provider.Enabled ? "Yes": "No")
            </td>
            <td class="text-end">
              <a asp-page="/Admin/Federation/Edit"
                 class="btn btn-link text-primary m-0 p-0"
                 asp-route-scheme="@provider.Scheme">
                <i class="bi bi-pencil-square"></i>
                <span class="d-none">Edit</span>
              </a>

              <button type="submit"
                      class="btn btn-link text-danger m-0 p-0"
                      form="delete-form"
                      name="Input.Button"
                      value="delete"
                      asp-page="/admin/Federation/delete"
                      asp-route-scheme="@provider.Scheme"
                      data-confirm="Are you sure you want to delete this provider?">
                <i class="bi bi-trash"></i>
                <span class="d-none">Delete</span>
              </button>

            </td>
          </tr>
        }
    </tbody>
</table>

<form id="delete-form" method="post" class="d-none"></form>

@if (!Model.Providers.Any())
{
    <div class="row">
        <div class="col">
            <div class="alert alert-light text-center">
                You do not have any External Providers configured.<br />
                Click "Create External Provider" above to begin adding a new provider.
            </div>
        </div>
    </div>
}
