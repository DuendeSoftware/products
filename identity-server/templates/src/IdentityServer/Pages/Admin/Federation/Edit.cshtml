@page
@model IdentityServerTemplate.Pages.Admin.Federation.EditModel

<div class="container-fluid mb-4 px-0">
    <header class="pb-3 mb-4 border-bottom">
        <h1 class=" fw-bold">
            <i class="bi bi-laptop text-brand"></i>
            Edit Provider - @Model.InputModel.Scheme
        </h1>
        <span class="text-muted">
            Edit the configuration for an existing external provider
        </span>
    </header>
</div>

@if (Model.Updated)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <strong>Success!</strong> External provider has been updated successfully.
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close">
        </button>
    </div>
}

<div class="clients-page">

    <partial name="_ValidationSummary" />

    <form method="post">
      <input type="hidden" asp-for="@Model.InputModel.Type" />
      <input type="hidden" asp-for="@Model.InputModel.Scheme" />

        <div class="form-group mb-3 text-start">

            <a class="btn btn-sm btn-outline-secondary" asp-page="/Admin/Federation/Index"
               data-unsaved="Any unsaved changes will be lost. Are you sure?">
                <i class="bi bi-chevron-double-left"></i>
                Go Back
            </a>

            <button class="btn btn-sm btn-brand"
                    type="submit"
                    name="Button"
                    value="save">
                <i class="bi bi-floppy"></i>
                Save Changes
            </button>

            <button class="btn btn-sm btn-danger"
                    type="submit"
                    name="Button"
                    value="delete"
                    data-confirm="Are you sure you want to delete this external provider?">
                <i class="bi bi-trash"></i>
                Delete
            </button>

        </div>

        <div class="row">

            <div class="col-12 col-md-6">

                <div class="card text-bg-light">
                    <h5 class="card-header">
                            <i class="bi bi-gear"></i>
                            External Provider Settings
                        </h5>
                        <div class="card-body pt-2">

                          <small class="mb-2 text-body-secondary d-block fst-italic">
                            Edit provider configuration.
                          </small>

                          <div class="form-group mb-3">
                            <label asp-for="@Model.InputModel.CallbackUrl" class="form-label"></label>
                            <input class="form-control form-control-sm" asp-for="@Model.InputModel.CallbackUrl" readonly disabled />
                          </div>

                          @if (Model.InputModel.Configuration.IsIconUrlEditable())
                          {
                              <div class="form-group mb-3">
                                  <label asp-for="@Model.InputModel.Configuration.IconUrl" class="form-label"></label>
                                  <input class="form-control form-control-sm" asp-for="@Model.InputModel.Configuration.IconUrl" autofocus />
                              </div>
                          }

                          <div class="form-group mb-3">
                            <label asp-for="@Model.InputModel.Name" class="form-label"></label>
                            <input class="form-control form-control-sm" asp-for="@Model.InputModel.Name" autofocus />
                          </div>

                          <div class="form-group mb-3">
                            <label class="form-label">
                              <input asp-for="@Model.InputModel.Enabled" type="checkbox" />

                              Enabled?
                            </label>
                          </div>

                          <hr />

                          @Html.EditorFor(model => Model.InputModel.Configuration)

                        </div>
                </div>

            </div>

        </div>


    </form>
</div>
