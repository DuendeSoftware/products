@page
@model IdentityServerHost.Pages.Admin.ApiScopes.IndexModel

<div class="container-fluid mb-4 px-0">
    <div class="d-flex justify-content-between align-items-center bg-body-tertiary rounded shadow-sm p-2 flex-nowrap">

        <!-- Page title -->
        <nav aria-label="breadcrumb" class="mb-0 ms-2">
            <ol class="breadcrumb mb-0 p-0 fs-5">
                <li class="breadcrumb-item active" aria-current="page">API Scopes</li>
            </ol>
        </nav>

        <!-- Actions: keep dropdown + form together, no wrap -->
        <div class="d-flex align-items-center flex-nowrap gap-2">

            <a class="btn btn-link" href="/Admin/ApiScopes/New">
                New Scope
            </a>

            <!-- Filter/Search form -->
            <form class="d-flex align-items-center flex-nowrap mb-0" role="search">
                <input class="form-control me-2"
                       type="text"
                       id="filter"
                       name="filter"
                       placeholder="Filter"
                       value="@Model.Filter" />

                <button class="btn btn-outline-success" type="submit">
                    Search
                </button>
            </form>

        </div>
    </div>
</div>

<table class="table mt-4">
    <thead class="table-light">
        <tr>
            <th>Name</th>
            <th>Display Name</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var scope in Model.Scopes)
        {
            <tr>
                <td><a asp-page="/Admin/ApiScopes/Edit" asp-route-id="@scope.Name">@scope.Name</a></td>
                <td>@scope.DisplayName</td>
            </tr>
        }
    </tbody>

</table>
