@page
@model IdentityServerHost.Pages.Admin.Clients.NewModel

<div class="container-fluid mb-4 px-0">
    <div class="d-flex justify-content-between align-items-center bg-body-tertiary rounded shadow-sm p-2 flex-nowrap">

        <!-- Page title -->
        <nav aria-label="breadcrumb" class="mb-0 ms-2">
            <ol class="breadcrumb mb-0 p-0 fs-5">
                <li class="breadcrumb-item active" aria-current="page">New Client</li>
            </ol>
        </nav>

    </div>
</div>

<div class="clients-page">
    @if (Model.Created)
    {
      <div class="alert alert-success" role="alert">
        <h4 class="alert-heading">Success!</h4>
        <p>
          Client Id `<em>@Model.InputModel.ClientId</em>` created!
          The client secret is displayed below. Copy it now, as it won't be shown again.
        </p>
        <hr>
        <pre class="mb-0">@Model.InputModel.Secret</pre>
        <hr />
        <p class="mb-0">Click here to <a asp-page="/Admin/Clients/Edit" asp-route-id="@Model.InputModel.ClientId">continue</a>.</p>
      </div>
    }
    else
    {
        <partial name="_ValidationSummary" />

        <div class="row">
            <div class="col-md-6">
                <form method="post">
                  <input type="hidden" asp-for="@Model.InputModel.Flow" />

                  <div class="form-group mb-3">
                        <label asp-for="@Model.InputModel.Flow"></label>
                        <select class="form-control readonly disabled" asp-for="@Model.InputModel.Flow" readonly disabled>
                            <option value="0">Client Credentials</option>
                            <option value="1">Code Flow (with PKCE)</option>
                        </select>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="@Model.InputModel.ClientId"></label>
                        <input class="form-control" asp-for="@Model.InputModel.ClientId" autofocus />
                    </div>
                    <div class="form-group mb-3">
                        <label asp-for="@Model.InputModel.Secret"></label>
                        <input class="form-control" asp-for="@Model.InputModel.Secret" />
                    </div>
                    <div class="form-group mb-3">
                      <label asp-for="InputModel.Name"></label>
                      <input
                          class="form-control"
                          asp-for="InputModel.Name"
                          autofocus />
                    </div>
                    
                    <div class="form-group mb-3">
                        <button class="btn btn-success" type="submit">Create Client</button>
                        <a class="btn btn-secondary" asp-page="/Admin/Clients/Index">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    }
</div>
