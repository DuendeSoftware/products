<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>IdentityServerHost</RootNamespace>

    <NoWarn>$(NoWarn);IDE0130</NoWarn><!-- Namespace does not match folder structure -->
    <NoWarn>$(NoWarn);CA2007</NoWarn><!-- Do not directly await a Task -->
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Duende.IdentityServer" Version="8.0.2" />
    <PackageReference Include="Serilog.AspNetCore" Version="10.0.0" />
  </ItemGroup>

</Project>
