@page
@model Duende.IdentityServer.UI.Pages.Ciba.IndexModel
@{
}

<div class="space-y-6">
    <div>
        @if (Model.LoginRequest.Client.LogoUri != null)
        {
            <div class="client-logo mb-4"><img src="@Model.LoginRequest.Client.LogoUri"></div>
        }
        <h1 class="text-2xl font-bold text-gray-900">
            @Model.LoginRequest.Client.ClientName
            <span class="text-lg font-normal text-gray-400">is requesting your permission</span>
        </h1>

        <div class="mt-4 bg-primary-50 border border-primary-200 rounded-card p-4">
            <p class="text-sm text-gray-700">
                Verify that this identifier matches what the client is displaying:
                <strong class="text-primary-700">@Model.LoginRequest.BindingMessage</strong>
            </p>
        </div>

        <p class="mt-4 text-gray-600">Do you wish to continue?</p>
        <div class="mt-3">
            <a class="inline-flex px-4 py-2 text-sm font-medium text-white bg-primary-600 rounded-md shadow-sm hover:bg-primary-700 transition-colors focus:outline-none focus:ring-2 focus:ring-primary-500" asp-page="/Ciba/Consent" asp-route-id="@Model.LoginRequest.InternalId">Yes, Continue</a>
        </div>
    </div>
</div>
