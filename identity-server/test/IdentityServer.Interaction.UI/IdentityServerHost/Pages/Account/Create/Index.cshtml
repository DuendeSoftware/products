@page
@model Duende.IdentityServer.UI.Pages.Account.Create.Index

<div class="space-y-6">
    <div>
        <h1 class="text-2xl font-bold text-gray-900">Create Account</h1>
    </div>

    <partial name="_ValidationSummary" />

    <div class="max-w-md">
        <div class="bg-white rounded-card shadow-sm border border-gray-200 p-6">
            <form asp-page="/Account/Create/Index" class="space-y-4">
                <input type="hidden" asp-for="Input.ReturnUrl" />

                <div>
                    <label asp-for="Input.Username" class="block text-sm font-medium text-gray-700 mb-1"></label>
                    <input class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500" placeholder="Username" asp-for="Input.Username" autofocus>
                </div>
                <div>
                    <label asp-for="Input.Password" class="block text-sm font-medium text-gray-700 mb-1"></label>
                    <input type="password" class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500" placeholder="Password" asp-for="Input.Password" autocomplete="off">
                </div>
                <div>
                    <label asp-for="Input.Name" class="block text-sm font-medium text-gray-700 mb-1"></label>
                    <input type="text" class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500" placeholder="Name" asp-for="Input.Name">
                </div>
                <div>
                    <label asp-for="Input.Email" class="block text-sm font-medium text-gray-700 mb-1"></label>
                    <input type="email" class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm text-sm focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-primary-500" placeholder="Email" asp-for="Input.Email">
                </div>

                <div class="flex gap-3 pt-2">
                    <button class="px-4 py-2 text-sm font-medium text-white bg-primary-600 rounded-md shadow-sm hover:bg-primary-700 transition-colors focus:outline-none focus:ring-2 focus:ring-primary-500" name="Input.Button" value="create">Create</button>
                    <button class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md shadow-sm hover:bg-gray-50 transition-colors focus:outline-none focus:ring-2 focus:ring-primary-500" name="Input.Button" value="cancel">Cancel</button>
                </div>
            </form>
        </div>
    </div>
</div>
