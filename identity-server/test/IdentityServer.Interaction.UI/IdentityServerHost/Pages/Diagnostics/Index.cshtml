@page
@model Duende.IdentityServer.UI.Pages.Diagnostics.Index

<div class="space-y-6">
    <h1 class="text-2xl font-bold text-gray-900">Authentication Cookie</h1>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white rounded-card shadow-sm border border-gray-200 overflow-hidden">
            <div class="px-4 py-3 border-b border-gray-200 bg-gray-50">
                <h2 class="text-lg font-semibold text-gray-800">Claims</h2>
            </div>
            <div class="p-4">
                @if(Model.View.AuthenticateResult.Principal != null)
                {
                    <dl class="divide-y divide-gray-100">
                        @foreach (var claim in Model.View.AuthenticateResult.Principal.Claims)
                        {
                            <div class="py-2 grid grid-cols-3 gap-2">
                                <dt class="text-xs font-medium text-gray-500 truncate">@claim.Type</dt>
                                <dd class="text-xs text-gray-800 col-span-2 break-all">@claim.Value</dd>
                            </div>
                        }
                    </dl>
                }
            </div>
        </div>

        <div class="bg-white rounded-card shadow-sm border border-gray-200 overflow-hidden">
            <div class="px-4 py-3 border-b border-gray-200 bg-gray-50">
                <h2 class="text-lg font-semibold text-gray-800">Properties</h2>
            </div>
            <div class="p-4">
                <dl class="divide-y divide-gray-100">
                    @if (Model.View.AuthenticateResult.Properties != null)
                    {
                        @foreach (var prop in Model.View.AuthenticateResult.Properties.Items)
                        {
                            <div class="py-2 grid grid-cols-3 gap-2">
                                <dt class="text-xs font-medium text-gray-500 truncate">@prop.Key</dt>
                                <dd class="text-xs text-gray-800 col-span-2 break-all">@prop.Value</dd>
                            </div>
                        }
                    }
                    @if (Model.View.Clients.Any())
                    {
                        <div class="py-2 grid grid-cols-3 gap-2">
                            <dt class="text-xs font-medium text-gray-500">Clients</dt>
                            <dd class="text-xs text-gray-800 col-span-2">
                                @{
                                    var clients = Model.View.Clients.ToArray();
                                    for(var i = 0; i < clients.Length; i++)
                                    {
                                        <text>@clients[i]</text>
                                        if (i < clients.Length - 1)
                                        {
                                            <text>, </text>
                                        }
                                    }
                                }
                            </dd>
                        </div>
                    }
                </dl>
            </div>
        </div>
    </div>
</div>
