    <PackageReference Include="Microsoft.Extensions.Http" Version="9.0.0" />
    <PackageReference Include="Duende.Bff.Client" Version="3.0.0-rc1" />
  </ItemGroup>

  <ItemGroup>

  </ItemGroup>

</Project>
