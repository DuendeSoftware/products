{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "bff": {

  },
  "UseJsonYarpConfig": false,
  "ReverseProxy": {
    "Routes": {
      "user-token": {
        "ClusterId": "cluster1",
        "Match": {
          "Path": "/yarp/user-token/{**catch-all}"
        },
        "Metadata": {
          "Duende.Bff.Yarp.TokenType": "User",
          "Duende.Bff.Yarp.AntiforgeryCheck": "true"
        }
      },
      "client-token": {
        "ClusterId": "cluster1",
        "Match": {
          "Path": "/yarp/client-token/{**catch-all}"
        },
        "Metadata": {
          "Duende.Bff.Yarp.TokenType": "Client",
          "Duende.Bff.Yarp.AntiforgeryCheck": "true"
        }
      },
      "user-or-client-token": {
        "ClusterId": "cluster1",
        "Match": {
          "Path": "/yarp/user-or-client-token/{**catch-all}"
        },
        "Metadata": {
          "Duende.Bff.Yarp.TokenType": "UserOrClient",
          "Duende.Bff.Yarp.AntiforgeryCheck": "true"
        }
      },
      "anonymous": {
        "ClusterId": "cluster1",
        "Match": {
          "Path": "/yarp/anonymous/{**catch-all}"
        },
        "Metadata": {
          "Duende.Bff.Yarp.AntiforgeryCheck": "true"
        }
      },
      "impersonation-route-level": {
        "ClusterId": "cluster1",
        "Match": {
          "Path": "/yarp/impersonation-route-level/{**catch-all}"
        },
        "Metadata": {
          "Duende.Bff.Yarp.TokenType": "User",
          "Duende.Bff.Yarp.AntiforgeryCheck": "true",
          "Duende.Bff.Yarp.AccessTokenRetriever": "Bff.ImpersonationAccessTokenRetriever, Hosts.Bff.MultiFrontend"
        }
      },
      "impersonation-cluster-level": {
        "ClusterId": "cluster-with-impersonation",
        "Match": {
          "Path": "/yarp/impersonation-cluster-level/{**catch-all}"
        },
        "Metadata": {
          "Duende.Bff.Yarp.TokenType": "User",
          "Duende.Bff.Yarp.AntiforgeryCheck": "true"
        }
      },
      "impersonation-route-overrides-cluster": {
        "ClusterId": "cluster-with-impersonation",
        "Match": {
          "Path": "/yarp/impersonation-route-overrides-cluster/{**catch-all}"
        },
        "Metadata": {
          "Duende.Bff.Yarp.TokenType": "User",
          "Duende.Bff.Yarp.AntiforgeryCheck": "true",
          "Duende.Bff.Yarp.AccessTokenRetriever": "NoOpAccessTokenRetriever, Hosts.Bff.MultiFrontend"
        }
      }
    },
    "Clusters": {
      "cluster1": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:5010"
          }
        }
      },
      "cluster-with-impersonation": {
        "Destinations": {
          "destination1": {
            "Address": "https://localhost:5010"
          }
        },
        "Metadata": {
          "Duende.Bff.Yarp.AccessTokenRetriever": "Bff.ImpersonationAccessTokenRetriever, Hosts.Bff.MultiFrontend"
        }
      }
    }
  }
}
