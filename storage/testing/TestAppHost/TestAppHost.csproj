<Project Sdk="Aspire.AppHost.Sdk">

  <PropertyGroup>
    <IsAspireHost>true</IsAspireHost>
    <OutputType>Exe</OutputType>
    <UserSecretsId>storage-test-app-host</UserSecretsId>
  </PropertyGroup>

  <PropertyGroup>
    <NoWarn>$(NoWarn);CA1848;CA1873;NU1903</NoWarn><!-- CA1848/CA1873: LoggerMessage delegates; NU1903: transitive vulnerability in Aspire host packages -->
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Aspire.Hosting.Oracle" />
    <PackageReference Include="Aspire.Hosting.PostgreSQL" />
    <PackageReference Include="Aspire.Hosting.SqlServer" />
  </ItemGroup>

</Project>
